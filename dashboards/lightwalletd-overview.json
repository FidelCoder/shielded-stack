{
  "title": "Lightwalletd Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "panels": [
    {
      "type": "stat",
      "title": "Reachable Endpoints",
      "targets": [
        {
          "expr": "sum(shielded_stack_endpoint_reachable)"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "stat",
      "title": "Max Height Lag",
      "targets": [
        {
          "expr": "max(shielded_stack_endpoint_height_lag)"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 0
      }
    },
    {
      "type": "timeseries",
      "title": "Endpoint Latency",
      "targets": [
        {
          "expr": "shielded_stack_endpoint_latency_seconds"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      }
    },
    {
      "type": "timeseries",
      "title": "Reported Block Height",
      "targets": [
        {
          "expr": "shielded_stack_endpoint_block_height"
        },
        {
          "expr": "shielded_stack_endpoint_estimated_height"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      }
    }
  ]
}
